# Copy to .env.local and fill in your store links (get URLs from the Uber Eats / DoorDash apps or store pages).

NEXT_PUBLIC_SITE_NAME=MIDNIGHT SMASHERS

# Site URL for sitemap and structured data (no trailing slash), e.g. https://yoursite.com
NEXT_PUBLIC_SITE_URL=

# Full URLs, including https://
NEXT_PUBLIC_UBER_EATS_URL=
NEXT_PUBLIC_DOORDASH_URL=
